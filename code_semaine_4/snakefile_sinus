LOADS = []
for i in range(1, 10):
    LOADS.append(f"{i}e-6")
for i in range(10, 100, 10):
    LOADS.append(f"{i}e-6")
    
HURSTS = ["0.8"]
PAS = "400" 
vit=[]
for i in range (0.1,1.1,0.1):
    vit.append(i)
rule all:
    input:
        # Snakemake va créer la liste de tous les fichiers attendus pour toutes les combinaisons
        expand("resultats/deformee_step_{pas}_load_{load}_H_{hurst}.png", pas=PAS, load=LOADS, hurst=HURSTS, V_cible=vit),
        expand("resultats/deformee_step_{pas}_load_{load}_H_{hurst}.txt", pas=PAS, load=LOADS, hurst=HURSTS, V_cible=vit),
        expand("resultats/courbe_fx_total_step_{pas}_load_{load}_H_{hurst}.png", pas=PAS, load=LOADS, hurst=HURSTS, V_cible=vit)

rule generer_deformee:
    output:
        plot="resultats/deformee_step_{pas}_load_{load}_H_{hurst}.png",
        data="resultats/deformee_step_{pas}_load_{load}_H_{hurst}.txt",
        curve="resultats/courbe_fx_total_step_{pas}_load_{load}_H_{hurst}.png" 
    shell:
        # Snakemake va injecter chaque charge automatiquement ici
        "python force_glissement_surf_sinus.py {wildcards.load} {wildcards.vit} {wildcards.hurst} {wildcards.pas}"